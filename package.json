{
  "name": "honktipbot",
  "version": "2.1.0",
  "description": "A multi-asset Telegram tipping bot for Bitcoin Cash CashTokens",
  "type": "module",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "wallet:setup": "node scripts/setup-wallet.js",
    "check": "node --check src/index.js && node --test",
    "test": "node --test",
    "test:coverage": "node --test --experimental-test-coverage"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "keywords": [
    "bitcoin-cash",
    "cashtokens",
    "telegram",
    "tipping-bot"
  ],
  "author": "honktipbot contributors",
  "license": "MIT",
  "dependencies": {
    "@bitauth/libauth": "3.1.0-next.8",
    "mainnet-js": "3.1.7",
    "telegraf": "4.16.3"
  }
}
